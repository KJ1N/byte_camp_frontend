# App
NODE_ENV=development

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3201

# API
PORT=3201
JWT_SECRET=replace-with-a-strong-dev-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bytecamp_aigc
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bytecamp_aigc

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# AI provider(OpenAI compatible)
# mock: always use local mock; live: require provider credentials; auto: use live only when key/model are configured
AI_PROVIDER_MODE=auto
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_API_KEY=replace-with-your-key
AI_MODEL=replace-with-your-model
AI_TIMEOUT_MS=60000
AI_MAX_RETRIES=1

# Asset cloud storage and CDN
# mock: return CDN-style URLs without network; s3: reserved for S3-compatible object storage integration
ASSET_STORAGE_MODE=mock
ASSET_CDN_BASE_URL=https://cdn.example.com
ASSET_BUCKET=bytecamp-assets
ASSET_REGION=auto
ASSET_ENDPOINT=
ASSET_ACCESS_KEY_ID=
ASSET_SECRET_ACCESS_KEY=

# Asset vision audit
# mock: deterministic filename-based audit; live: require AI_API_KEY and ASSET_VISION_MODEL; auto: live when configured otherwise mock
ASSET_AUDIT_MODE=mock
ASSET_VISION_MODEL=
