# App
NODE_ENV=development

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# API
PORT=3001
JWT_SECRET=replace-with-a-strong-dev-secret-at-least-32-chars
JWT_EXPIRES_IN=7d

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bytecamp_aigc
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bytecamp_aigc

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# AI provider(OpenAI compatible)
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_API_KEY=replace-with-your-key
AI_MODEL=replace-with-your-model

