{
  "name": "@bytecamp-aigc/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "corepack pnpm --filter @bytecamp-aigc/shared build && nest build",
    "dev": "corepack pnpm --filter @bytecamp-aigc/shared build && nest start --watch",
    "start": "corepack pnpm --filter @bytecamp-aigc/shared build && nest start",
    "start:dev": "corepack pnpm --filter @bytecamp-aigc/shared build && nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --test -r ts-node/register src/**/*.spec.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "node scripts/run-prisma-with-root-env.mjs generate",
    "prisma:migrate": "node scripts/run-prisma-with-root-env.mjs migrate dev",
    "prisma:seed": "node scripts/run-prisma-with-root-env.mjs db seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@bytecamp-aigc/shared": "workspace:*",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.9",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.78.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.8.2",
    "openai": "^4.104.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.10.1",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
